# ADB Android Control - Device Configuration TEMPLATE
#
# Copy to device.env and fill in your own values. NEVER commit device.env
# to a public repo — it is in .gitignore for that reason.
#
# How to populate each field:
#   ./scripts/adb_controller.py --discover  (writes a fresh device.env)
# Or fill in manually using `adb shell getprop` / `adb shell dumpsys`.

# =============================================================================
# DEVICE
# =============================================================================
DEVICE_NAME="<your friendly name, e.g. MyPhone>"
DEVICE_MODEL="<adb shell getprop ro.product.model>"
DEVICE_BRAND="<adb shell getprop ro.product.brand>"

# Persistent identifiers — DO NOT share these publicly
DEVICE_SERIAL="<adb get-serialno>"
DEVICE_ANDROID_ID="<adb shell settings get secure android_id>"
DEVICE_FINGERPRINT="<adb shell getprop ro.build.fingerprint>"

ANDROID_VERSION="<adb shell getprop ro.build.version.release>"
SDK_VERSION="<adb shell getprop ro.build.version.sdk>"

# =============================================================================
# WIRELESS ADB CONNECTION (Multi-Network)
# =============================================================================
# You can have multiple network entries; the active one is set below.

# Example: Home Network
ADB_HOME_SSID="<your home WiFi SSID>"
ADB_HOME_IP="<device IP on home network, e.g. 192.168.1.100>"
ADB_HOME_PORT="<wireless ADB port, e.g. 5555 or randomized>"

# Example: Mobile/Travel Network
ADB_MOBILE_SSID="<other WiFi SSID>"
ADB_MOBILE_IP="<device IP on that network>"
ADB_MOBILE_PORT="<port>"

# Currently active (one of the above)
ADB_WIRELESS_IP="<active IP>"
ADB_WIRELESS_PORT="<active port>"

# Service config
ADB_RECONNECT_INTERVAL="30"
ADB_PORT_SCAN_START="30000"
ADB_PORT_SCAN_END="50000"

# =============================================================================
# RADIO SPECS (filled in by scripts/radio_scan.py)
# =============================================================================
WIFI_SSID=""
WIFI_BSSID=""           # ⚠️ Geolocatable — never commit a real value
WIFI_FREQUENCY_MHZ=""
WIFI_CHANNEL=""
WIFI_BAND=""
WIFI_STANDARD=""
WIFI_LINK_SPEED_MBPS=""
WIFI_RSSI_DBM=""

WIFI_MIMO="false"
WIFI_DUAL_BAND_SIMULTANEOUS="false"
WIFI_6GHZ_SUPPORT="false"
WIFI_WPA3_SUPPORT="false"

# =============================================================================
# BLUETOOTH
# =============================================================================
BLUETOOTH_ENABLED="false"
BLUETOOTH_STATE="OFF"
BLUETOOTH_NAME=""       # ⚠️ Often contains real first name
BLUETOOTH_ADDRESS=""    # ⚠️ Persistent identifier

# =============================================================================
# USB DEVICE (optional — for OTG dev work)
# =============================================================================
USB_DEVICE_PATH=""
USB_VID=""
USB_PID=""
USB_VENDOR=""
USB_PRODUCT=""

# =============================================================================
# PATHS (where this skill lives on the host)
# =============================================================================
SKILL_DIR="~/.claude/skills/adb-android-control"
SCRIPTS_DIR="~/.claude/skills/adb-android-control/scripts"
TERMUX_DIR="~/.claude/skills/adb-android-control/termux"

SERVICE_NAME="adb-autoconnect"
SERVICE_STATUS="stopped"
BOOT_SCRIPT="~/.termux/boot/adb-autoconnect"

# =============================================================================
# API ACCESS (informational; auto-detected at runtime)
# =============================================================================
TERMUX_API_WIFI="unknown"
TERMUX_API_BLUETOOTH="unknown"
TERMUX_API_USB="unknown"
ADB_SHELL_ACCESS="unknown"
ADB_DUMPSYS_ACCESS="unknown"

# =============================================================================
# FEATURE FLAGS
# =============================================================================
FEATURE_WIFI_SCAN="true"
FEATURE_WIFI_STATUS="true"
FEATURE_BLUETOOTH_STATUS="true"
FEATURE_USB_DETECT="true"
FEATURE_RADIO_CAPS="true"
FEATURE_AUTO_CONNECT="true"
